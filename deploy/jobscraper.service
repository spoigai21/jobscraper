[Unit]
Description=Internship job monitor (ntfy alerts)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
ExecStart=__APP_DIR__/.venv/bin/python __APP_DIR__/main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
