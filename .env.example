# Copy this file to `.env` and fill in your credentials.
# Never commit `.env` to version control.

# --- Twilio SMS alerts ---
# Create a Twilio account at https://www.twilio.com/try-twilio
# Find Account SID and Auth Token on the Twilio Console dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Buy or verify a phone number in Twilio Console > Phone Numbers.
TWILIO_FROM_NUMBER=
# Your personal mobile number in E.164 format (e.g. +14155551234).
TWILIO_TO_NUMBER=

# --- ntfy push notifications ---
# Sign up at https://ntfy.sh or self-host; pick a unique topic name.
# Subscribe on your phone with the ntfy app or browser.
NTFY_TOPIC=

# --- Gmail email alerts ---
# Use a Google account with 2FA enabled.
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Destination inbox for alert emails (can match GMAIL_ADDRESS).
ALERT_EMAIL_TO=

# --- Polling schedule (seconds) ---
# How often to check during business hours (default: 2700 = 45 minutes).
POLL_INTERVAL_BUSINESS=2700
# How often to check outside business hours (default: 10800 = 3 hours).
POLL_INTERVAL_OVERNIGHT=10800
# Business-hour window in US Eastern time (24-hour clock).
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19

# --- HTTP and alert throttling ---
# Request timeout in seconds for careers page fetches.
REQUEST_TIMEOUT=15
# Minimum seconds between repeat alerts for the same company.
MIN_ALERT_INTERVAL=3600

# --- Persistence ---
# SQLite database path for poll state and alert history (default: monitor.db in project root).
# On Railway, mount a volume and set e.g. MONITOR_DB_PATH=/data/monitor.db so state survives redeploys.
MONITOR_DB_PATH=

# --- HTTP client ---
# Optional override; defaults to a realistic Chrome user agent string.
USER_AGENT=
