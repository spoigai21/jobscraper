# Copy this file to `.env` and fill in your credentials.
# Never commit `.env` to version control.

# --- Twilio SMS alerts ---
# Create a Twilio account at https://www.twilio.com/try-twilio
# Find Account SID and Auth Token on the Twilio Console dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Buy or verify a phone number in Twilio Console > Phone Numbers.
TWILIO_FROM_NUMBER=
# Your personal mobile number in E.164 format (e.g. +14155551234).
TWILIO_TO_NUMBER=

# --- Discord push notifications (primary) ---
# When set, alerts + heartbeats post to this Discord channel webhook instead
# of ntfy. Create it in Discord: Channel → Edit → Integrations → Webhooks →
# New Webhook → Copy Webhook URL. Reachable from hosts where ntfy.sh is blocked.
DISCORD_WEBHOOK_URL=

# --- ntfy push notifications (fallback) ---
# Sign up at https://ntfy.sh or self-host; pick a unique topic name.
# Subscribe on your phone with the ntfy app or browser.
NTFY_TOPIC=
# Access token from https://ntfy.sh/account (required for email delivery).
NTFY_TOKEN=

# Destination inbox for alert emails.
# Verify this address and create NTFY_TOKEN at https://ntfy.sh/account
ALERT_EMAIL_TO=

# --- Parallel polling (optional) ---
# Number of companies to poll concurrently (default: 1 = sequential).
# Example: POLL_WORKERS=4 overlaps HTTP fetches across companies.
POLL_WORKERS=1
# Max concurrent requests per careers-site domain (default: 2).
POLL_DOMAIN_MAX_CONCURRENT=2

# --- Polling schedule (seconds) ---
# How often to check during business hours (default: 2700 = 45 minutes).
POLL_INTERVAL_BUSINESS=2700
# How often to check outside business hours (default: 10800 = 3 hours).
POLL_INTERVAL_OVERNIGHT=10800
# Business-hour window in US Eastern time (24-hour clock).
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19

# --- HTTP and alert throttling ---
# Request timeout in seconds for careers page fetches.
REQUEST_TIMEOUT=15
# Minimum seconds between repeat alerts for the same company.
MIN_ALERT_INTERVAL=3600
# Days to suppress a repeat alert for the same employer + role. Companies close
# and re-list the same internship under a new job ID every few weeks, which
# otherwise looks like a brand new posting. Set to 0 to disable.
ALERT_DEDUP_WINDOW_DAYS=30
# Skip a listing seen for the first time if the source says it was posted more
# than this many days ago — catches stale backfill when an aggregator feed
# re-indexes. Only applies to sources that report a publish date (Simplify).
# Age is measured from the posting date, not from your poll history, so an
# outage never drops jobs. Set to 0 to disable.
MAX_NEW_LISTING_AGE_DAYS=14

# --- Health ping (monitor alive notification) ---
# Send a low-priority ntfy push on this interval (default: 86400 = 24 hours).
HEALTH_PING_INTERVAL_SECONDS=86400
# Set to false to disable periodic health pings.
HEALTH_PING_ENABLED=true

# --- Persistence ---
# SQLite database path for poll state and alert history (default: monitor.db in project root).
# On Railway, mount a volume and set e.g. MONITOR_DB_PATH=/data/monitor.db so state survives redeploys.
MONITOR_DB_PATH=

# --- HTTP client ---
# Optional override; defaults to a realistic Chrome user agent string.
USER_AGENT=
